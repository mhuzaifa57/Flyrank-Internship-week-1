      "source": [
        "# Your turn — Discovery A restricted to pages with impressions_90d > 0\n",
        "seen = df[df[\"impressions_90d\"] > 0]\n",
        "\n",
        "corr_all  = df[\"search_volume\"].corr(df[\"impressions_90d\"])\n",
        "corr_seen = seen[\"search_volume\"].corr(seen[\"impressions_90d\"])\n",
        "\n",
        "print(f\"Correlation, all pages:              {corr_all:.3f}   (n={len(df)})\")\n",
        "print(f\"Correlation, impressions_90d > 0:    {corr_seen:.3f}   (n={len(seen)})\")\n",
        "print(f\"\\nDropped {len(df) - len(seen)} pages with zero impressions.\")"
      ],
