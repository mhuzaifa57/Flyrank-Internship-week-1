      "source": [
        "# Your experiment here\n",
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "# --- 1. Does a deeper tree help, and can you still read it? ---\n",
        "for depth in (2, 3, 4):\n",
        "    t = DecisionTreeClassifier(max_depth=depth, class_weight=\"balanced\", random_state=42).fit(X, y)\n",
        "    score = t.predict_proba(X)[:, 1]\n",
        "    print(f\"max_depth={depth}  Precision@50: {precision_at_k(score, y, 50):.3f}  \"\n",
        "          f\"(leaves: {t.get_n_leaves()})\")\n",
        "\n",
        "print()\n",
        "\n",
        "# --- 2. Swap features: drop impressions_90d, add engagement_rate ---\n",
        "features_v2 = [\"content_age_days\", \"days_since_last_update\", \"avg_position\",\n",
        "               \"ctr\", \"word_count\", \"engagement_rate\"]\n",
        "X_v2 = df[features_v2].replace([np.inf, -np.inf], np.nan).fillna(0)\n",
        "\n",
        "tree_v2 = DecisionTreeClassifier(max_depth=2, class_weight=\"balanced\", random_state=42).fit(X_v2, y)\n",
        "print(\"Tree with impressions_90d swapped out for engagement_rate:\")\n",
        "print(export_text(tree_v2, feature_names=features_v2))\n",
        "print(f\"Precision@50: {precision_at_k(tree_v2.predict_proba(X_v2)[:,1], y, 50):.3f}\")\n",
        "\n",
        "print()\n",
        "\n",
        "# --- 3. Honest check: does the depth-2 gap over the hand rule hold on a held-out split? ---\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y, test_size=0.3, random_state=42, stratify=y\n",
        ")\n",
        "tree_split = DecisionTreeClassifier(max_depth=2, class_weight=\"balanced\", random_state=42)\n",
        "tree_split.fit(X_train, y_train)\n",
        "\n",
        "test_scores = tree_split.predict_proba(X_test)[:, 1]\n",
        "hand_rule_test = df.loc[X_test.index, \"hand_rule_score\"]\n",
        "y_test_arr = np.asarray(y_test)\n",
        "\n",
        "print(\"On a held-out 30% test split:\")\n",
        "print(f\"  Hand rule  Precision@50: {precision_at_k(hand_rule_test, y_test_arr, 50):.3f}\")\n",
        "print(f\"  Tree       Precision@50: {precision_at_k(test_scores, y_test_arr, 50):.3f}\")"
      ],
